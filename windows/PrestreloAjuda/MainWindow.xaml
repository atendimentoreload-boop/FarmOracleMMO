<Window x:Class="PrestreloAjuda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FarmOracleMMO"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        Width="320" Height="440" MinWidth="240" MinHeight="220"
        ResizeMode="CanResizeWithGrip" SizeToContent="Manual"
        FontFamily="Segoe UI" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">
    <Border x:Name="RootBorder" CornerRadius="14" BorderThickness="1">
        <Grid>
            <DockPanel LastChildFill="True">
                <ContentControl x:Name="HeaderHost" DockPanel.Dock="Top"/>
                <ContentControl x:Name="BottomHost" DockPanel.Dock="Bottom"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="0">
                    <StackPanel x:Name="ContentHost" Margin="10"/>
                </ScrollViewer>
            </DockPanel>
            <ContentControl x:Name="SettingsHost" Visibility="Collapsed"/>
            <ContentControl x:Name="TeamsHost" Visibility="Collapsed"/>
            <ContentControl x:Name="CooldownHost" Visibility="Collapsed"/>
            <ContentControl x:Name="HelpHost" Visibility="Collapsed"/>
            <ContentControl x:Name="CaptureHost" Visibility="Collapsed"/>
            <ContentControl x:Name="BlockHost" Visibility="Collapsed"/>
        </Grid>
    </Border>
</Window>
